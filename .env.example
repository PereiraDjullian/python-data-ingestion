# =============================================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# APIs IBGE / SIDRA
# ---------------------------------------------------------------------------
IBGE_BASE_URL=https://servicodados.ibge.gov.br/api/v1
SIDRA_BASE_URL=https://apisidra.ibge.gov.br
REQUEST_TIMEOUT=30
REQUEST_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# SQL Server — Autenticação Windows (padrão)
# Atenção: se usar SQL Server Express, o servidor geralmente é localhost\SQLEXPRESS
# ---------------------------------------------------------------------------
DB_SERVER=localhost
DB_NAME=faculdade_db
DB_SCHEMA=bronze
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=true

# ---------------------------------------------------------------------------
# SQL Server — Autenticação SQL (alternativa, descomente se necessário)
# ---------------------------------------------------------------------------
# DB_TRUSTED_CONNECTION=false
# DB_USER=seu_usuario
# DB_PASSWORD=sua_senha

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
